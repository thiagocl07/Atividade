@page "/"
@rendermode InteractiveServer
@inject IProdutoService ProdutoService
@inject IMovimentacaoService MovimentacaoService

<PageTitle>Registro de produtos</PageTitle>

<div class="page-shell">
    <section class="section-intro">
        <h1>Controle de estoque</h1>
        <p>Registre, atualize e pesquise produtos com persistência em memória.</p>
    </section>

    @if (!string.IsNullOrWhiteSpace(mensagem))
    {
        <div class="alert alert-success" role="alert">
            @mensagem
        </div>
    }

    @if (!string.IsNullOrWhiteSpace(erroMensagem))
    {
        <div class="alert alert-danger" role="alert">
            @erroMensagem
        </div>
    }

    @if (produtosAbaixoDoMinimo.Any())
    {
        <div class="alert alert-warning alert-dismissible fade show mb-4" role="alert">
            <strong>⚠️ Atenção: Produtos com estoque baixo</strong>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            <div class="mt-2">
                @foreach (var prod in produtosAbaixoDoMinimo)
                {
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <span><strong>@prod.Codigo</strong> - @prod.Nome: Estoque atual @prod.EstoqueAtual / Mínimo @prod.EstoqueMinimo</span>
                        <span class="badge bg-danger">Faltam @(prod.EstoqueMinimo - prod.EstoqueAtual) unidades</span>
                    </div>
                }
            </div>
        </div>
    }

    <div class="row gx-4">
        <div class="col-lg-5">
            <div class="card mb-4">
                <div class="card-header">Dados do produto</div>
                <div class="card-body">
                    <div class="mb-3">
                        <label class="form-label">Código</label>
                        <input class="form-control" @bind="codigo" placeholder="Ex: PRD-001" disabled="@editing" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Nome</label>
                        <input class="form-control" @bind="nome" placeholder="Nome do produto" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Categoria</label>
                        <select class="form-select" @bind="categoria">
                            <option value="">Selecione...</option>
                            @foreach (var item in Categorias)
                            {
                                <option value="@item">@item</option>
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Fornecedor</label>
                        <select class="form-select" @bind="fornecedor">
                            <option value="">Selecione...</option>
                            @foreach (var item in Fornecedores)
                            {
                                <option value="@item">@item</option>
                            }
                        </select>
                    </div>

                    <div class="row g-3 mb-3">
                        <div class="col-sm-6">
                            <label class="form-label">Preço unitário</label>
                            <input class="form-control" type="number" min="0" step="0.01" @bind="precoUnitario" />
                        </div>
                        <div class="col-sm-6">
                            <label class="form-label">Estoque mínimo</label>
                            <input class="form-control" type="number" min="0" @bind="estoqueMinimo" />
                        </div>
                    </div>

                    <div class="d-flex gap-2 flex-wrap">
                        <button type="button" class="btn btn-primary" @onclick="SalvarProduto">@ButtonText</button>
                        <button type="button" class="btn btn-outline-secondary" @onclick="ResetForm">Limpar</button>
                    </div>
                </div>
            </div>

            <div class="card mb-4">
                <div class="card-header">Busca por código</div>
                <div class="card-body">
                    <div class="input-group mb-3">
                        <input class="form-control" placeholder="Informe o código" @bind="codigoBusca" />
                        <button type="button" class="btn btn-outline-primary" @onclick="BuscarPorCodigo">Buscar</button>
                    </div>

                    @if (resultadosBusca.Any())
                    {
                        <div class="search-results">
                            @foreach (var produto in resultadosBusca)
                            {
                                <div class="result-item">
                                    <strong>@produto.Codigo</strong> — @produto.Nome
                                </div>
                            }
                        </div>
                    }
                    else if (!string.IsNullOrWhiteSpace(codigoBusca))
                    {
                        <p class="text-muted">Nenhum produto encontrado para esse código.</p>
                    }
                </div>
            </div>

            <div class="card mb-4">
                <div class="card-header">Movimentação de estoque</div>
                <div class="card-body">
                    <div class="mb-3">
                        <label class="form-label">Produto</label>
                        <select class="form-select" @bind="produtoMovimentacaoId">
                            <option value="">Selecione um produto...</option>
                            @foreach (var prod in produtos)
                            {
                                <option value="@prod.Id">@prod.Codigo - @prod.Nome</option>
                            }
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Tipo</label>
                        <select class="form-select" @bind="tipoMovimentacao">
                            <option value="">Selecione...</option>
                            <option value="Entrada">Entrada</option>
                            <option value="Saida">Saída</option>
                            <option value="Ajuste">Ajuste</option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Quantidade</label>
                        <input class="form-control" type="number" min="1" @bind="quantidadeMovimentacao" placeholder="0" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Motivo</label>
                        <input class="form-control" @bind="motivoMovimentacao" placeholder="Descreva o motivo" />
                    </div>

                    <button type="button" class="btn btn-success w-100" @onclick="RegistrarMovimentacao">Registrar</button>
                </div>
            </div>
        </div>

        <div class="col-lg-7">
            <div class="card mb-4">
                <div class="card-header d-flex align-items-center justify-content-between">
                    <span>Produtos cadastrados</span>
                    <button class="btn btn-sm btn-outline-secondary" @onclick="LoadProducts">Atualizar lista</button>
                </div>
                <div class="card-body">
                    @if (!produtos.Any())
                    {
                        <p class="text-muted">Nenhum produto cadastrado ainda.</p>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-hover table-sm align-middle mb-0">
                                <thead>
                                    <tr>
                                        <th>Código</th>
                                        <th>Nome</th>
                                        <th>Categoria</th>
                                        <th>Fornecedor</th>
                                        <th>Estoque</th>
                                        <th>Min.</th>
                                        <th>Ações</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var produto in produtos)
                                    {
                                        <tr>
                                            <td>@produto.Codigo</td>
                                            <td>@produto.Nome</td>
                                            <td>@produto.Categoria</td>
                                            <td>@produto.Fornecedor</td>
                                            <td>@produto.EstoqueAtual</td>
                                            <td>@produto.EstoqueMinimo</td>
                                            <td>
                                                <button type="button" class="btn btn-sm btn-outline-primary me-1" @onclick="() => Editar(produto)">Editar</button>
                                                <button type="button" class="btn btn-sm btn-outline-danger" @onclick="() => Excluir(produto.Id)">Excluir</button>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private IReadOnlyCollection<ProdutoModel> produtos = Array.Empty<ProdutoModel>();
    private IReadOnlyCollection<ProdutoModel> produtosAbaixoDoMinimo = Array.Empty<ProdutoModel>();
    private IReadOnlyCollection<ProdutoModel> resultadosBusca = Array.Empty<ProdutoModel>();
    private string codigo = string.Empty;
    private string nome = string.Empty;
    private string categoria = string.Empty;
    private string fornecedor = string.Empty;
    private decimal precoUnitario;
    private int estoqueMinimo;
    private string codigoBusca = string.Empty;
    private Guid? produtoParaEditar;
    private string produtoMovimentacaoId = string.Empty;
    private string tipoMovimentacao = string.Empty;
    private int quantidadeMovimentacao;
    private string motivoMovimentacao = string.Empty;
    private string? mensagem;
    private string? erroMensagem;

    private bool editing => produtoParaEditar.HasValue;
    private string ButtonText => editing ? "Salvar alterações" : "Criar produto";

    protected override void OnInitialized()
    {
        LoadProducts();
    }

    private void MostrarMensagem(string texto)
    {
        mensagem = texto;
        erroMensagem = null;
    }

    private void MostrarErro(string texto)
    {
        erroMensagem = texto;
        mensagem = null;
    }

    private void LimparMensagens()
    {
        mensagem = null;
        erroMensagem = null;
    }

    private void LoadProducts()
    {
        produtos = ProdutoService.ObterTodos();
        produtosAbaixoDoMinimo = produtos.Where(p => p.EstoqueAtual < p.EstoqueMinimo).ToArray();
        if (string.IsNullOrWhiteSpace(categoria)) categoria = Categorias.FirstOrDefault() ?? "Geral";
        if (string.IsNullOrWhiteSpace(fornecedor)) fornecedor = Fornecedores.FirstOrDefault() ?? "Fornecedor Padrão";
    }

    private IReadOnlyCollection<string> Categorias => ProdutoService.ObterCategorias();
    private IReadOnlyCollection<string> Fornecedores => ProdutoService.ObterFornecedores();

    private void SalvarProduto()
    {
        LimparMensagens();
        try
        {
            if (produtoParaEditar is Guid id)
            {
                ProdutoService.AtualizarProduto(id, nome, precoUnitario, estoqueMinimo);
                MostrarMensagem("Produto atualizado com sucesso.");
            }
            else
            {
                ProdutoService.CriarProduto(codigo, nome, categoria, fornecedor, precoUnitario, estoqueMinimo);
                MostrarMensagem("Produto cadastrado com sucesso.");
            }

            ResetForm();
            LoadProducts();
        }
        catch (Exception ex)
        {
            MostrarErro(ex.Message);
        }
    }

    private void BuscarPorCodigo()
    {
        LimparMensagens();
        resultadosBusca = string.IsNullOrWhiteSpace(codigoBusca)
            ? Array.Empty<ProdutoModel>()
            : ProdutoService.ObterPorCodigo(codigoBusca);
    }

    private void Editar(ProdutoModel produto)
    {
        produtoParaEditar = produto.Id;
        codigo = produto.Codigo;
        nome = produto.Nome;
        categoria = produto.Categoria;
        fornecedor = produto.Fornecedor;
        precoUnitario = produto.PrecoUnitario;
        estoqueMinimo = produto.EstoqueMinimo;
    }

    private void Excluir(Guid id)
    {
        LimparMensagens();
        try
        {
            ProdutoService.DeletarProduto(id);
            LoadProducts();
            ResetForm();
            MostrarMensagem("Produto excluído com sucesso.");
        }
        catch (Exception ex)
        {
            MostrarErro(ex.Message);
        }
    }

    private void RegistrarMovimentacao()
    {
        LimparMensagens();
        if (!Guid.TryParse(produtoMovimentacaoId, out var prodId))
        {
            MostrarErro("Selecione um produto válido para movimentação.");
            return;
        }

        var produto = produtos.FirstOrDefault(p => p.Id == prodId);
        if (produto is null || string.IsNullOrWhiteSpace(tipoMovimentacao) || quantidadeMovimentacao <= 0 || string.IsNullOrWhiteSpace(motivoMovimentacao))
        {
            MostrarErro("Preencha todos os dados de movimentação corretamente.");
            return;
        }

        try
        {
            MovimentacaoService.RegistrarMovimentacao(
                produto.Codigo,
                tipoMovimentacao,
                quantidadeMovimentacao,
                produto.EstoqueAtual,
                0,
                motivoMovimentacao);

            produtoMovimentacaoId = string.Empty;
            tipoMovimentacao = string.Empty;
            quantidadeMovimentacao = 0;
            motivoMovimentacao = string.Empty;
            LoadProducts();
            MostrarMensagem("Movimentação registrada com sucesso.");
        }
        catch (Exception ex)
        {
            MostrarErro(ex.Message);
        }
    }

    private void ResetForm()
    {
        produtoParaEditar = null;
        codigo = string.Empty;
        nome = string.Empty;
        categoria = string.Empty;
        fornecedor = string.Empty;
        precoUnitario = 0;
        estoqueMinimo = 0;
        LimparMensagens();
    }
}
